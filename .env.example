# ══════════════════════════════════════════════════════
#  Task Manager API — Development environment template
#  Copy to .env and fill in the values before running.
#
#  cp .env.example .env
# ══════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────
APP_NAME=Task Manager API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
APP_PORT=8000

# ── Database — app connection ──────────────────────────
# Host must match the service name defined in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/taskmanager
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/taskmanager_test

# ── Database — PostgreSQL container ───────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager

# ── JWT ────────────────────────────────────────────────
# NEVER use this value in production.
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-do-not-use-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── API Documentation ──────────────────────────────────
# HTTP Basic Auth credentials that protect /docs, /redoc and /openapi.json.
# Change these before exposing the service to any network.
DOCS_USERNAME=admin
DOCS_PASSWORD=admin
