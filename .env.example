# ══════════════════════════════════════════════════════
#  Task Manager API — Development environment template
#  Copy to .env and fill in the values before running.
#
#  cp .env.example .env
# ══════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────
APP_NAME=Task Manager API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
APP_PORT=8000

# ── Database ───────────────────────────────────────────
# When running with Docker Compose, POSTGRES_HOST must match
# the service name defined in docker-compose.yml (i.e. "db").
# For local development without Docker, set it to "localhost".
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager
POSTGRES_TEST_DB=taskmanager_test

# ── JWT ────────────────────────────────────────────────
# NEVER use this value in production.
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-do-not-use-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── API Documentation ──────────────────────────────────
# HTTP Basic Auth credentials that protect /docs, /redoc and /openapi.json.
# Change these before exposing the service to any network.
DOCS_USERNAME=admin
DOCS_PASSWORD=admin
