# ══════════════════════════════════════════════════════
#  Task Manager API — Production environment template
#  Copy to .env.prod and fill in ALL values before deploying.
#
#  cp .env.prod.example .env.prod
#
#  IMPORTANT: never commit .env.prod to version control.
#  In CI/CD pipelines inject secrets via your secrets manager
#  (AWS Secrets Manager, Vault, GitHub Actions secrets, etc.).
# ══════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────
APP_NAME=Task Manager API
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
APP_PORT=8000

# ── Docker image ───────────────────────────────────────
IMAGE_TAG=latest

# ── Database ───────────────────────────────────────────
# POSTGRES_HOST must match the service name in docker-compose.prod.yml (i.e. "db").
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=taskmanager

# ── JWT ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── API Documentation ──────────────────────────────────
# HTTP Basic Auth credentials that protect /docs, /redoc and /openapi.json.
# Use a strong, unique password. Consider disabling docs entirely in production
# by blocking /docs and /redoc at the Nginx level if external access is not needed.
DOCS_USERNAME=CHANGE_ME
DOCS_PASSWORD=CHANGE_ME
